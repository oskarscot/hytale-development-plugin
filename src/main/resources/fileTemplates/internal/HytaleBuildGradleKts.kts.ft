plugins {
    id("java")
}

group = "${PACKAGE}"
version = "0.0.1"

java {
    toolchain {
        languageVersion = JavaLanguageVersion.of(25)
    }
}

repositories {
    mavenCentral()
    maven("https://maven.hytale.com/${PATCHLINE}")
}

dependencies {
    compileOnly("com.hypixel.hytale:Server:${HYTALE_VERSION}")
}
